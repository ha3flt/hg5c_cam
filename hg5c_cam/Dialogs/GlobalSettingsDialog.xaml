<Window x:Class="hg5c_cam.Dialogs.GlobalSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Program settings" Height="475" Width="560" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="LanguageLabel" Grid.Row="0" Text="Language"/>
        <ComboBox x:Name="LanguageComboBox" Grid.Row="1" Margin="0,4,0,0"/>
        <Separator Grid.Row="2" Margin="0,12,0,8"/>

        <CheckBox x:Name="EnableSoundCheckBox" Grid.Row="3" Content="Enable sound"/>

        <TextBlock x:Name="AudioDeviceLabel" Grid.Row="4" Text="Audio output" Margin="0,12,0,4"/>

        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="AudioDevicesListBox" Grid.Column="0" Height="100"/>
            <Button x:Name="RefreshButton" Grid.Column="2" Content="Refresh" Width="90" Height="28" VerticalAlignment="Top"/>
        </Grid>

        <TextBlock x:Name="SoundLevelLabel" Grid.Row="6" Text="Sound level" Margin="0,12,0,4"/>
        <Slider x:Name="SoundLevelSlider" Grid.Row="7" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"/>

        <Separator Grid.Row="8" Margin="0,12,0,8"/>
        <TextBlock x:Name="SplitPlaybackCameraCountLabel" Grid.Row="9" Text="Number of cameras shown simultaneously" Margin="0,0,0,4"/>
        <Grid Grid.Row="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SplitPlaybackCameraCountTextBox" Width="50" VerticalAlignment="Center" TextAlignment="Right" HorizontalAlignment="Left"/>
            <UniformGrid Grid.Column="2" Columns="8" Rows="1" Margin="0,0,60,0">
                <Button Content="1" Tag="1" Margin="2,0,12,0" Click="SplitPlaybackQuickButton_OnClick"/>
                <Button Content="2" Tag="2" Margin="2,0,12,0" Click="SplitPlaybackQuickButton_OnClick"/>
                <Button Content="3" Tag="3" Margin="2,0,12,0" Click="SplitPlaybackQuickButton_OnClick"/>
                <Button Content="4" Tag="4" Margin="2,0,12,0" Click="SplitPlaybackQuickButton_OnClick"/>
                <Button Content="5" Tag="5" Margin="2,0,12,0" Click="SplitPlaybackQuickButton_OnClick"/>
                <Button Content="6" Tag="6" Margin="2,0,12,0" Click="SplitPlaybackQuickButton_OnClick"/>
                <Button Content="7" Tag="7" Margin="2,0,12,0" Click="SplitPlaybackQuickButton_OnClick"/>
                <Button Content="8" Tag="8" Margin="2,0,12,0" Click="SplitPlaybackQuickButton_OnClick"/>
            </UniformGrid>
        </Grid>
        <CheckBox x:Name="AlwaysMaximizedPlaybackCheckBox" Grid.Row="11" Content="Always maximized playback" Margin="0,12,0,0"/>
        <CheckBox x:Name="TopmostMainWindowCheckBox" Grid.Row="12" Content="Topmost main window" Margin="0,8,0,0"/>

        <StackPanel Grid.Row="14" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,16,0,0">
            <Button x:Name="OkButton" Content="OK" Width="90" Margin="0,0,8,0" IsDefault="True"/>
            <Button x:Name="CancelButton" Content="Cancel" Width="90" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
