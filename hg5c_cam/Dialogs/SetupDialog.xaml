<Window x:Class="hg5c_cam.Dialogs.SetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="500" Width="760" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock x:Name="CameraNameLabel" Text="Camera name"/>
                <TextBox x:Name="CameraNameTextBox" Margin="0,4,0,0" FontSize="14"/>
                <Separator Margin="0,12,0,8"/>
                <CheckBox x:Name="UseOnvifCheckBox" Content="Use ONVIF"/>
                <CheckBox x:Name="AutoResolveOnvifCheckBox" Content="Resolve RTSP from ONVIF before playback" Margin="0,6,0,0"/>
                <TextBlock x:Name="OnvifDeviceServiceUrlLabel" Text="ONVIF device service URL" Margin="0,6,0,0"/>
                <TextBox x:Name="OnvifDeviceServiceUrlTextBox" Margin="0,4,0,0"/>
                <TextBlock x:Name="OnvifProfileTokenLabel" Text="ONVIF profile token (optional)" Margin="0,4,0,0"/>
                <ComboBox x:Name="OnvifProfileTokenComboBox" IsEditable="True" IsTextSearchEnabled="False" Margin="0,4,0,0"/>
                <TextBlock x:Name="UsernameLabel" Text="Name" Margin="0,10,0,0"/>
                <TextBox x:Name="UsernameTextBox" Margin="0,4,0,0"/>
                <TextBlock x:Name="PasswordLabel" Text="Password" Margin="0,4,0,0"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,4,0,0"/>
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button x:Name="ResolveOnvifButton" Content="Resolve RTSP from ONVIF" Width="190" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="ResolveOnvifStatusText" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#FF24802A" Visibility="Collapsed"/>
                </StackPanel>
                <TextBlock x:Name="RtspUrlLabel" Text="RTSP URL" Margin="0,8,0,0"/>
                <ComboBox x:Name="UrlComboBox" IsEditable="True" IsTextSearchEnabled="False" Margin="0,4,0,0" Text="rtsp://"/>
                <TextBlock x:Name="PictureSizeText" Margin="0,8,0,0" Text="Picture size:"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock x:Name="AspectRatioLabel" Text="Aspect ratio"/>
                <ComboBox x:Name="AspectRatioComboBox" Margin="0,4,0,0"/>
                <CheckBox x:Name="WindowMaximizedCheckBox" Content="Maximized" Margin="0,8,0,0"/>
                <CheckBox x:Name="SoundCheckBox" Content="Stream sound" Margin="0,4,0,0"/>
                <TextBlock x:Name="SoundLevelLabel" Text="Sound level" Margin="0,6,0,0"/>
                <Slider x:Name="SoundLevelSlider" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"/>
                <Separator Margin="0,12,0,8"/>
                <TextBlock x:Name="MaxFpsLabel" Text="Max. displayed FPS (0 = unlimited)"/>
                <TextBox x:Name="MaxFpsTextBox" Margin="0,4,0,0"/>
                <TextBlock x:Name="ConnectionDelayLabel" Text="Connection delay (sec)" Margin="0,6,0,0"/>
                <TextBox x:Name="ReconnectDelayTextBox" Margin="0,4,0,0"/>
                <TextBlock x:Name="ConnectionRetriesLabel" Text="Connection retries" Margin="0,6,0,0"/>
                <TextBox x:Name="RetriesTextBox" Margin="0,4,0,0"/>
                <TextBlock x:Name="NetworkTimeoutLabel" Text="Network timeout" Margin="0,6,0,0"/>
                <TextBox x:Name="NetworkTimeoutTextBox" Margin="0,4,0,0"/>
                <Separator Margin="0,16,0,8"/>
                <CheckBox x:Name="FpsOverlayCheckBox" Content="FPS overlay"/>
                <TextBlock x:Name="FpsOverlayPositionLabel" Text="FPS overlay position" Margin="0,6,0,0"/>
                <ComboBox x:Name="FpsOverlayPositionComboBox" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="OkButton" Content="OK" Width="90" Margin="0,0,8,0" IsEnabled="False"/>
            <Button x:Name="CancelButton" Content="Cancel" Width="90" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
