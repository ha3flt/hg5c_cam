<Window x:Class="hg5c_cam.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About" Width="320" SizeToContent="Height" MinHeight="180" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <StackPanel VerticalAlignment="Center">
            <TextBlock x:Name="AppNameText" Text="hg5c_cam" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock x:Name="AboutBodyText" Text="ONVIF RTSP camera viewer by HA3FLT" Margin="0,10,0,0" HorizontalAlignment="Center"/>
            <TextBlock x:Name="FrameworkText" Margin="0,4,0,0" HorizontalAlignment="Center"><Run Text=".NET 8 WPF on Win 7+, FFmpeg"/></TextBlock>
            <TextBlock x:Name="VersionText" Margin="0,8,0,0" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
