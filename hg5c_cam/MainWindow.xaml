<Window x:Class="hg5c_cam.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="hg5c_cam" Height="520" Width="920" WindowStartupLocation="Manual" KeyDown="MainWindow_OnKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Menu x:Name="MenuBar" Grid.Column="0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Background="Transparent">
                <MenuItem x:Name="FileMenuItem" Header="_File">
                    <MenuItem x:Name="GlobalSettingsMenuItem" Header="_Program settings" Click="GlobalSettingsMenuItem_OnClick"/>
                    <Separator/>
                    <MenuItem x:Name="ImportMenuItem" Header="_Import" Click="ImportMenuItem_OnClick"/>
                    <MenuItem x:Name="ExportMenuItem" Header="_Export" Click="ExportMenuItem_OnClick"/>
                    <MenuItem x:Name="DefaultsMenuItem" Header="_Defaults" Click="DefaultsMenuItem_OnClick"/>
                    <Separator/>
                    <MenuItem x:Name="ExitMenuItem" Header="_Exit" Click="ExitMenuItem_OnClick"/>
                </MenuItem>
                <MenuItem x:Name="CameraMenuItem" Header="_Camera">
                    <MenuItem x:Name="CameraSettingsMenuItem" Header="_Camera settings" Click="CameraSettingsMenuItem_OnClick"/>
                    <Separator/>
                    <MenuItem Header="Camera 1" Tag="1" IsCheckable="True" Click="CameraProfileMenuItem_OnClick"/>
                    <MenuItem Header="Camera 2" Tag="2" IsCheckable="True" Click="CameraProfileMenuItem_OnClick"/>
                    <MenuItem Header="Camera 3" Tag="3" IsCheckable="True" Click="CameraProfileMenuItem_OnClick"/>
                    <MenuItem Header="Camera 4" Tag="4" IsCheckable="True" Click="CameraProfileMenuItem_OnClick"/>
                    <MenuItem Header="Camera 5" Tag="5" IsCheckable="True" Click="CameraProfileMenuItem_OnClick"/>
                    <MenuItem Header="Camera 6" Tag="6" IsCheckable="True" Click="CameraProfileMenuItem_OnClick"/>
                    <MenuItem Header="Camera 7" Tag="7" IsCheckable="True" Click="CameraProfileMenuItem_OnClick"/>
                    <MenuItem Header="Camera 8" Tag="8" IsCheckable="True" Click="CameraProfileMenuItem_OnClick"/>
                </MenuItem>
                <MenuItem x:Name="ViewMenuItem" Header="_View">
                    <MenuItem x:Name="StartStreamMenuItem" Header="_Start stream" IsCheckable="True" Click="StartStreamMenuItem_OnClick"/>
                    <MenuItem x:Name="StopStreamMenuItem" Header="Sto_p stream" IsCheckable="True" Click="StopStreamMenuItem_OnClick"/>
                    <Separator/>
                    <MenuItem x:Name="HighQualityMenuItem" Header="_High quality" IsCheckable="True" Click="HighQualityMenuItem_OnClick"/>
                    <MenuItem x:Name="LowBandwidthMenuItem" Header="_Low bandwidth" IsCheckable="True" Click="LowBandwidthMenuItem_OnClick"/>
                    <Separator/>
                    <MenuItem x:Name="StreamSoundMenuItem" Header="Strea_m sound" IsCheckable="True" Click="StreamSoundMenuItem_OnClick"/>
                    <MenuItem x:Name="FpsOverlayMenuItem" Header="_FPS overlay" IsCheckable="True" Click="FpsOverlayMenuItem_OnClick"/>
                    <Separator/>
                    <MenuItem x:Name="TopmostMenuItem" Header="_Topmost window" IsCheckable="True" Click="TopmostMenuItem_OnClick"/>
                </MenuItem>
                <MenuItem x:Name="HelpRootMenuItem" Header="_Help">
                    <MenuItem x:Name="HelpMenuItem" Header="_Help" Click="HelpMenuItem_OnClick"/>
                    <Separator/>
                    <MenuItem x:Name="AboutMenuItem" Header="_About" Click="AboutMenuItem_OnClick"/>
                </MenuItem>
            </Menu>

            <ToolBarTray Grid.Column="1" Background="Transparent" IsLocked="True">
                <ToolBar x:Name="SplitPlaybackToolBar" Band="0" Padding="0" Margin="4,0,4,0" BorderThickness="0" Background="Transparent" FontSize="14" FontWeight="SemiBold">
                    <ToggleButton Tag="StartStop" Width="28" Height="28" Margin="2,1" FontSize="12" ToolTipService.Placement="Top" ToolTipService.HorizontalOffset="0" ToolTipService.VerticalOffset="-4" Click="StartStopToolbarButton_OnClick">
                        <TextBlock Text="ON" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ToggleButton>
                    <ToggleButton Tag="Quality" Width="28" Height="28" Margin="2,1" ToolTipService.Placement="Top" ToolTipService.HorizontalOffset="0" ToolTipService.VerticalOffset="-4" Click="QualityToolbarButton_OnClick">
                        <TextBlock Text="HD" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ToggleButton>
                    <ToggleButton Tag="Sound" Width="28" Height="28" Margin="2,1" ToolTipService.Placement="Top" ToolTipService.HorizontalOffset="0" ToolTipService.VerticalOffset="-4" Click="SoundToolbarButton_OnClick">
                        <TextBlock Text="🔊" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ToggleButton>
                    <ToggleButton Tag="Fps" Width="28" Height="28" Margin="2,1" ToolTipService.Placement="Top" ToolTipService.HorizontalOffset="0" ToolTipService.VerticalOffset="-4" Click="FpsToolbarButton_OnClick">
                        <TextBlock Text="i" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ToggleButton>
                    <Separator Margin="6,0,4,0"/>
                    <ToggleButton Content="1" Tag="SplitCount:1" Width="28" Margin="2,1" ToolTipService.Placement="Top" ToolTipService.HorizontalOffset="0" ToolTipService.VerticalOffset="-4" Click="SplitPlaybackToolbarButton_OnClick"/>
                    <ToggleButton Content="4" Tag="SplitCount:4" Width="28" Margin="2,1" ToolTipService.Placement="Top" ToolTipService.HorizontalOffset="0" ToolTipService.VerticalOffset="-4" Click="SplitPlaybackToolbarButton_OnClick"/>
                    <Button Content="-" Tag="SplitCount:Down" Width="28" Margin="2,1" ToolTipService.Placement="Top" ToolTipService.HorizontalOffset="0" ToolTipService.VerticalOffset="-4" Click="SplitPlaybackToolbarStepDown_OnClick"/>
                    <Button Content="+" Tag="SplitCount:Up" Width="28" Margin="2,1" ToolTipService.Placement="Top" ToolTipService.HorizontalOffset="0" ToolTipService.VerticalOffset="-4" Click="SplitPlaybackToolbarStepUp_OnClick"/>
                    <Separator Margin="6,0,4,0"/>

                    <ToggleButton Content="1" Tag="ActiveSlot:1" Width="28" Margin="2,1" ToolTipService.Placement="Top" ToolTipService.HorizontalOffset="0" ToolTipService.VerticalOffset="-4" Click="ActiveVisibleCameraToolbarButton_OnClick"/>
                    <ToggleButton Content="2" Tag="ActiveSlot:2" Width="28" Margin="2,1" ToolTipService.Placement="Top" ToolTipService.HorizontalOffset="0" ToolTipService.VerticalOffset="-4" Click="ActiveVisibleCameraToolbarButton_OnClick"/>
                    <ToggleButton Content="3" Tag="ActiveSlot:3" Width="28" Margin="2,1" ToolTipService.Placement="Top" ToolTipService.HorizontalOffset="0" ToolTipService.VerticalOffset="-4" Click="ActiveVisibleCameraToolbarButton_OnClick"/>
                    <ToggleButton Content="4" Tag="ActiveSlot:4" Width="28" Margin="2,1" ToolTipService.Placement="Top" ToolTipService.HorizontalOffset="0" ToolTipService.VerticalOffset="-4" Click="ActiveVisibleCameraToolbarButton_OnClick"/>
                    <Button Content="-" Tag="ActiveSlot:Down" Width="28" Margin="2,1" ToolTipService.Placement="Top" ToolTipService.HorizontalOffset="0" ToolTipService.VerticalOffset="-4" Click="ActiveVisibleCameraToolbarStepDown_OnClick"/>
                    <Button Content="+" Tag="ActiveSlot:Up" Width="28" Margin="2,1" ToolTipService.Placement="Top" ToolTipService.HorizontalOffset="0" ToolTipService.VerticalOffset="-4" Click="ActiveVisibleCameraToolbarStepUp_OnClick"/>
                    <Separator Margin="6,0,4,0"/>
                    <ToggleButton Tag="Topmost" Width="28" Height="28" Margin="2,1" ToolTipService.Placement="Top" ToolTipService.HorizontalOffset="0" ToolTipService.VerticalOffset="-4" Click="TopmostToolbarButton_OnClick">
                        <TextBlock Text="📌" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ToggleButton>
                </ToolBar>
            </ToolBarTray>
        </Grid>
        <Grid x:Name="VideoHost" Grid.Row="1" Background="Black" ClipToBounds="True" MouseLeftButtonDown="VideoHost_OnMouseLeftButtonDown" MouseLeftButtonUp="VideoHost_OnMouseLeftButtonUp" MouseEnter="VideoHost_OnMouseEnter" MouseLeave="VideoHost_OnMouseLeave" MouseMove="VideoHost_OnMouseMove">
            <Grid x:Name="PlaybackGrid" Background="Black"/>
            <Border x:Name="PresetsOverlayBorder" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="10" Padding="8,6" Background="#77000000" CornerRadius="8" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="PresetsOverlayTitleText" Grid.Row="0" Text="Presets" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4" HorizontalAlignment="Center" TextAlignment="Center"/>
                    <Rectangle Grid.Row="1" Height="1" Fill="#99FFFFFF" Opacity="0.45" Margin="0,0,0,6"/>

                    <ListBox Grid.Row="2"
                             x:Name="PresetsOverlayList"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             SelectionChanged="PresetsOverlayList_OnSelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
            <Border x:Name="NavigationOverlayBorder" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10" Padding="8" Background="#77000000" CornerRadius="8" Visibility="Collapsed">
                <Grid>
                    <Grid.Resources>
                        <Style x:Key="NavigationButtonStyle" TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#E0E0E0E0"/>
                            <Setter Property="BorderBrush" Value="#E0E0E0E0"/>
                            <Setter Property="BorderThickness" Value="1.5"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontWeight" Value="Black"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="ButtonBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FFF0F0F0"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FFFFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Grid.Resources>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="NavigationOverlayTitleText" Grid.Row="0" Text="Navigation" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,4"/>
                    <Rectangle Grid.Row="1" Height="1" Fill="#99FFFFFF" Opacity="0.45" Margin="0,0,0,6"/>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource NavigationButtonStyle}" Tag="UpFast" Content="↑↑" Width="32" Height="26" Margin="2,2,2,2" PreviewMouseLeftButtonDown="NavigationButton_OnPreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="NavigationButton_OnPreviewMouseLeftButtonUp"/>
                        <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource NavigationButtonStyle}" Tag="LeftFast" Content="←←" Width="32" Height="26" Margin="2,2,2,2" PreviewMouseLeftButtonDown="NavigationButton_OnPreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="NavigationButton_OnPreviewMouseLeftButtonUp"/>
                        <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource NavigationButtonStyle}" Tag="Left" Content="←" Width="32" Height="26" Margin="2,2,2,2" PreviewMouseLeftButtonDown="NavigationButton_OnPreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="NavigationButton_OnPreviewMouseLeftButtonUp"/>
                        <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource NavigationButtonStyle}" Tag="Up" Content="↑" Width="32" Height="26" Margin="2,2,2,2" PreviewMouseLeftButtonDown="NavigationButton_OnPreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="NavigationButton_OnPreviewMouseLeftButtonUp"/>
                        <Button Grid.Row="2" Grid.Column="3" Style="{StaticResource NavigationButtonStyle}" Tag="Right" Content="→" Width="32" Height="26" Margin="2,2,2,2" PreviewMouseLeftButtonDown="NavigationButton_OnPreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="NavigationButton_OnPreviewMouseLeftButtonUp"/>
                        <Button Grid.Row="2" Grid.Column="4" Style="{StaticResource NavigationButtonStyle}" Tag="RightFast" Content="→→" Width="32" Height="26" Margin="2,2,2,2" PreviewMouseLeftButtonDown="NavigationButton_OnPreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="NavigationButton_OnPreviewMouseLeftButtonUp"/>
                        <Button Grid.Row="3" Grid.Column="2" Style="{StaticResource NavigationButtonStyle}" Tag="Down" Content="↓" Width="32" Height="26" Margin="2,2,2,2" PreviewMouseLeftButtonDown="NavigationButton_OnPreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="NavigationButton_OnPreviewMouseLeftButtonUp"/>
                        <Button Grid.Row="5" Grid.Column="0" Style="{StaticResource NavigationButtonStyle}" Tag="ZoomOutFast" Content="--" Width="32" Height="26" Margin="2,2,2,2" PreviewMouseLeftButtonDown="NavigationButton_OnPreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="NavigationButton_OnPreviewMouseLeftButtonUp"/>
                        <Button Grid.Row="5" Grid.Column="1" Style="{StaticResource NavigationButtonStyle}" Tag="ZoomOut" Content="-" Width="32" Height="26" Margin="2,2,2,2" PreviewMouseLeftButtonDown="NavigationButton_OnPreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="NavigationButton_OnPreviewMouseLeftButtonUp"/>
                        <Button Grid.Row="4" Grid.Column="2" Style="{StaticResource NavigationButtonStyle}" Tag="DownFast" Content="↓↓" Width="32" Height="26" Margin="2,2,2,2" PreviewMouseLeftButtonDown="NavigationButton_OnPreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="NavigationButton_OnPreviewMouseLeftButtonUp"/>
                        <Button Grid.Row="5" Grid.Column="3" Style="{StaticResource NavigationButtonStyle}" Tag="ZoomIn" Content="+" Width="32" Height="26" Margin="2,2,2,2" PreviewMouseLeftButtonDown="NavigationButton_OnPreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="NavigationButton_OnPreviewMouseLeftButtonUp"/>
                        <Button Grid.Row="5" Grid.Column="4" Style="{StaticResource NavigationButtonStyle}" Tag="ZoomInFast" Content="++" Width="32" Height="26" Margin="2,2,2,2" PreviewMouseLeftButtonDown="NavigationButton_OnPreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="NavigationButton_OnPreviewMouseLeftButtonUp"/>
                    </Grid>
                </Grid>
            </Border>
            <Grid x:Name="StatusOverlay" Visibility="Visible">
                <Rectangle Fill="Black" Opacity="0.55"/>
                <TextBlock x:Name="StatusText" Text="Disconnected" Foreground="White" FontWeight="Bold" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
